# ============================================================
# LiteLLM Proxy
# ============================================================
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-mysecretkey
LITELLM_MASTER_KEY=sk-mysecretkey
LITELLM_MODEL=oai-gpt-4.1-nano

# OpenAI API key - pouzivan v litellm_config.yaml + Docker
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY_HERE

# ============================================================
# MCP Server
# ============================================================
MCP_SERVER_URL=http://localhost:8002

# ============================================================
# Microsoft Azure AD (pro SharePoint Graph API)
# ============================================================
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ============================================================
# SharePoint
# ============================================================
# Bud URL webu (doporuceno):
SHAREPOINT_SITE_URL=https://yourtenant.sharepoint.com/sites/yoursite
# nebo zvlast:
# SHAREPOINT_SITE_HOSTNAME=yourtenant.sharepoint.com
# SHAREPOINT_SITE_PATH=/sites/yoursite

# Drive (document library) - alespon jedno z:
SHAREPOINT_DRIVE_NAME=Documents
# SHAREPOINT_DRIVE_ID=b!xxxxx

# Zdrojova slozka (kde jsou PDF soubory / kde je slozka "Statements of the account...")
SHAREPOINT_FOLDER_PATH=Shared Documents/Invoices

# Cilova slozka "sent" - alespon jedno z:
SHAREPOINT_SENT_FOLDER_PATH=Shared Documents/Invoices/sent
# SHAREPOINT_SENT_FOLDER_ID=xxxxx

# ============================================================
# Zpracovani - davka
# ============================================================
BATCH_SIZE=50
STATE_DB_PATH=data/processing_state.db

# ============================================================
# Testovaci rezim
# ============================================================
# TEST_MODE=true -> emaily jdou jen na TEST_RECIPIENT_EMAIL
TEST_MODE=true
TEST_RECIPIENT_EMAIL=test@example.com

# ============================================================
# Mapovaci Excel (zakaznik -> email)
# ============================================================
MAPPING_EXCEL_PATH=data/customer_emails.xlsx
MAPPING_ID_COLUMN=customer_id
MAPPING_EMAIL_COLUMN=email
# Volitelne - druhy sloupec s emailem:
# MAPPING_EMAIL_COLUMN2=email2

# ============================================================
# BCC v ostrem rezimu
# ============================================================
# PROD_BCC_EMAIL=archive@example.com

# ============================================================
# SMTP
# ============================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=sender@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true
EMAIL_FROM=sender@example.com

# ============================================================
# Sablony emailu
# ============================================================
EMAIL_SUBJECT_TEMPLATE=Vase faktury - zakaznik {customer_id}
EMAIL_BODY_TEMPLATE=v priloze Vam posilame Vas dokument.\n\nS pozdravem,\nVas dodavatel
